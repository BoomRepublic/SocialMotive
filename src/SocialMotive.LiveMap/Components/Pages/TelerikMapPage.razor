@page "/telerik"
@implements IAsyncDisposable
@inject NavigationManager Navigation

<PageTitle>Telerik Map — SocialMotive Live Map</PageTitle>

<div class="map-container">
    <TelerikMap Zoom="7"
                Center="@_mapCenter">
        <MapLayers>
            <MapLayer Type="@MapLayersType.Tile"
                      UrlTemplate="https://a.tile.openstreetmap.org/{z}/{x}/{y}.png"
                      Attribution="&copy; OpenStreetMap contributors" />
            <MapLayer Type="@MapLayersType.Marker"
                      Data="@_markers"
                      LocationField="@nameof(MapMarkerData.LatLng)"
                      TitleField="@nameof(MapMarkerData.Title)" />
        </MapLayers>
    </TelerikMap>
</div>

@code {
    private HubConnection? _hubConnection;
    private List<TrackerLocation> _trackerLocations = new();
    private List<MapMarkerData> _markers = new();
    private double[] _mapCenter = [52.37, 4.90]; // Amsterdam default

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/locationhub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<List<TrackerLocation>>("ReceiveLocations", (locations) =>
        {
            _trackerLocations = locations;
            _markers = locations.Select(l => new MapMarkerData
            {
                LatLng = [l.Latitude, l.Longitude],
                Title = $"{l.DisplayName} — {l.Timestamp:HH:mm:ss} UTC"
            }).ToList();

            if (_markers.Count > 0)
            {
                _mapCenter = [_markers.Average(m => m.LatLng[0]), _markers.Average(m => m.LatLng[1])];
            }

            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }

    private class MapMarkerData
    {
        public double[] LatLng { get; set; } = [];
        public string Title { get; set; } = string.Empty;
    }
}
