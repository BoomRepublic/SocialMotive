@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IServiceScopeFactory ScopeFactory

<PageTitle>SocialMotive Live Map</PageTitle>

<div id="leaflet-map" class="map-container"></div>

@code {
    private IJSObjectReference? _module;
    private List<TrackerLocation>? _initialLocations;

    protected override async Task OnInitializedAsync()
    {
        // Load latest location per tracker from DB during server-side initialization
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<SocialMotiveDbContext>();

        _initialLocations = await (
            from t in db.Trackers
            join l in db.Locations on t.TrackerId equals l.TrackerId
            where t.IsActive
            && l.LocationId == db.Locations
                .Where(loc => loc.TrackerId == t.TrackerId)
                .OrderByDescending(loc => loc.Timestamp)
                .Select(loc => loc.LocationId)
                .FirstOrDefault()
            select new TrackerLocation
            {
                TrackerId = t.TrackerId,
                DisplayName = t.DisplayName,
                Latitude = l.Latitude,
                Longitude = l.Longitude,
                AccuracyMeters = l.AccuracyMeters,
                SpeedKmh = l.SpeedKmh,
                HeadingDegrees = l.HeadingDegrees,
                Timestamp = l.Timestamp,
            })
            .AsNoTracking()
            .ToListAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/leafletMap.js");

        // Initialize map with markers and start browser-side SignalR for live updates
        await _module.InvokeVoidAsync("initMap", "leaflet-map", _initialLocations);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("destroyMap"); } catch (JSDisconnectedException) { }
            await _module.DisposeAsync();
        }
    }
}
