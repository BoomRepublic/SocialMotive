@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Leaflet / OSM — SocialMotive Live Map</PageTitle>

<div id="leaflet-map" class="map-container"></div>

@code {
    private HubConnection? _hubConnection;
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/leafletMap.js");
        await _module.InvokeVoidAsync("initMap", "leaflet-map");

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/locationhub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<List<TrackerLocation>>("ReceiveLocations", async (locations) =>
        {
            if (_module is not null)
                await _module.InvokeVoidAsync("updateMarkers", locations);
        });

        await _hubConnection.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();

        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("destroyMap"); } catch (JSDisconnectedException) { }
            await _module.DisposeAsync();
        }
    }
}
