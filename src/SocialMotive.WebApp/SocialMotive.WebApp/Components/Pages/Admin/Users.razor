@page "/admin/users"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "AdminFull")]

<PageTitle>Admin - Users</PageTitle>

<div class="admin-table-container">
    <div class="page-header">
        <h1>Users Management</h1>
        <p class="text-muted">View, create, update, and delete user accounts</p>
    </div>

    <!-- TODO: Implement Telerik Grid component via MCP -->
    <!-- Features needed:
         - Read: GET /api/admin/users (paginated, sortable, filterable)
         - Create: POST /api/admin/users with UserDto
         - Update: PUT /api/admin/users/{id} with UserDto
         - Delete: DELETE /api/admin/users/{id}
         - Export: CSV/Excel export
         - Grid Columns: UserId, Email, FirstName, LastName, Phone, Bio, ProfileImage, IsActive, CreatedUtc, UpdatedUtc, Actions
         - Edit Mode: Inline or popup
         - Validation: Email required, FirstName/LastName required
    -->

    <div class="alert alert-info">
        <p><strong>Status:</strong> Grid component implementation pending. Use Telerik MCP patterns for:</p>
        <ul>
            <li>TelerikGrid with pageable, sortable, filterable settings</li>
            <li>GridCommandButton for inline edit/delete</li>
            <li>GridEditMode.Inline or PopUp</li>
            <li>Export to CSV/Excel via GridExcelExport</li>
        </ul>
    </div>
</div>

<style>
    .admin-table-container {
        padding: 2rem;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-header h1 {
        margin-bottom: 0.5rem;
    }
</style>
