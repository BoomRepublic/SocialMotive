@inherits LayoutComponentBase

@implements IDisposable

@inject NavigationManager NavManager

<TelerikRootComponent IconType="@IconType.Font">

    <TelerikAppBar ThemeColor="@ThemeConstants.AppBar.ThemeColor.Base"
                   Class="appbar-top">
        <AppBarSection>
            <TelerikButton Icon="@FontIcon.Menu"
                           FillMode="@ThemeConstants.Button.FillMode.Clear"
                           OnClick="@( () => DrawerExpanded = !DrawerExpanded )" />
        </AppBarSection>
        <AppBarSection>
            <div id="app-title">
                <svg width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M17.2477 14.5932C17.2477 14.7922 17.1047 15.0366 16.926 15.1344L12.4541 17.6552V7.92806L3.83203 3.06798L8.30392 0.547161C8.47908 0.445909 8.76863 0.445909 8.94736 0.547161L17.2477 5.22918V14.5932ZM10.5381 9.0139L4.63275 5.67957C4.45759 5.58181 4.16805 5.58181 3.98931 5.67957L0 7.93155L6.22705 11.4439V18.4687L10.2164 16.2167C10.3915 16.1155 10.5381 15.8711 10.5381 15.6721V9.0104V9.0139ZM0 14.9563L4.30746 17.3864V12.5228L0 14.9563Z" fill="#96CA4F" />
                </svg>
                <NavLink href="/"><strong>Progress</strong><sup>&reg;</sup> Telerik<sup>&reg;</sup> UI for Blazor</NavLink>
            </div>
        </AppBarSection>
        <AppBarSpacer />
        <AppBarSection>
            <a href="https://www.telerik.com/blazor-ui" target="_blank" id="product-page-link"
               title="Go to Telerik UI for Blazor Product Page">Telerik UI for Blazor Product Page</a>
        </AppBarSection>
    </TelerikAppBar>

    <TelerikDrawer Data="@DrawerData"
                   Expanded="@DrawerExpanded"
                   ExpandedChanged="@DrawerExpandedChanged"
                   @bind-SelectedItem="@DrawerSelectedItem"
                   Mode="@DrawerMode.Push"
                   MiniMode="true"
                   Class="mainlayout-drawer">
        <ItemTemplate>
            @{
                var item = context as MainLayout.NavItem;
            }
            <div class="drawer-item-wrapper">
                <div class="drawer-item">
                    <span class="drawer-item-text">@item?.Text</span>
                </div>
                @if (item?.Children != null && item.Children.Count > 0)
                {
                    <div class="drawer-children">
                        @foreach (var child in item.Children)
                        {
                            <div class="drawer-child">
                                @if (child.Children != null && child.Children.Count > 0)
                                {
                                    <div class="drawer-child-text">
                                        <span>@child.Text</span>
                                    </div>
                                    <div class="drawer-grandchildren">
                                        @foreach (var grandchild in child.Children)
                                        {
                                            <NavLink href="@grandchild.Url" class="drawer-grandchild">
                                                <span>@grandchild.Text</span>
                                            </NavLink>
                                        }
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(child.Url))
                                {
                                    <NavLink href="@child.Url" class="drawer-child-text">
                                        <span>@child.Text</span>
                                    </NavLink>
                                }
                                else
                                {
                                    <span class="drawer-child-text">@child.Text</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </ItemTemplate>
        <DrawerContent>
            <main>
                @Body
            </main>
            @if (DrawerExpanded)
            {
                <AICodingAssistant />
            }
        </DrawerContent>
    </TelerikDrawer>

    <TelerikAppBar ThemeColor="@ThemeConstants.AppBar.ThemeColor.Base"
                   Class="appbar-bottom">
        <AppBarSpacer />
        <AppBarSection>
            <div id="copyright">Copyright &copy; @DateTime.Today.Year Progress Software. All rights reserved.</div>
        </AppBarSection>
        <AppBarSpacer />
    </TelerikAppBar>

    <TelerikMediaQuery Media="(min-width: 641px)" OnChange="@OnMediaQueryChange" />

</TelerikRootComponent>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private IEnumerable<NavItem> DrawerData { get; set; } = new List<NavItem>()
    {
        new NavItem("Home", FontIcon.Home, "/"),
        new NavItem("Counter", FontIcon.CustomFormat, "/counter"),
        new NavItem("Weather", FontIcon.Globe, "/weather"),
        new NavItem("About", FontIcon.InfoCircle, "/about"),
        new NavItem("Admin", null, "/admin", new List<NavItem>()
        {
            new NavItem("Dashboard", null, "/admin"),
            new NavItem("SocialMotive Tables", null, null, new List<NavItem>()
            {
                new NavItem("Users", null, "/admin/users"),
                new NavItem("Trackers", null, "/admin/trackers"),
                new NavItem("Events", null, "/admin/events"),
                new NavItem("Event Types", null, "/admin/eventtypes"),
                new NavItem("Event Tasks", null, "/admin/eventtasks"),
                new NavItem("Event Participants", null, "/admin/eventparticipants"),
                new NavItem("Task Assignments", null, "/admin/eventtaskassignments"),
                new NavItem("Groups", null, "/admin/groups"),
                new NavItem("Labels", null, "/admin/labels"),
                new NavItem("Tracker Labels", null, "/admin/trackerlabels"),
                new NavItem("Tracker Roles", null, "/admin/trackerroles"),
                new NavItem("Cities", null, "/admin/cities"),
                new NavItem("Locations", null, "/admin/locations"),
                new NavItem("Invites", null, "/admin/invites"),
                new NavItem("Settings", null, "/admin/settings"),
                new NavItem("User Accounts", null, "/admin/useraccounts")
            }),
            new NavItem("TrekkerGenerator Tables", null, null, new List<NavItem>()
            {
                new NavItem("Templates", null, "/admin/templates"),
                new NavItem("Assets", null, "/admin/assets"),
                new NavItem("Layers", null, "/admin/layers"),
                new NavItem("Render Jobs", null, "/admin/renderjobs")
            })
        })
    };

    private bool DrawerExpanded { get; set; } = true;

    private NavItem? DrawerSelectedItem { get; set; }

    private bool LargeScreen { get; set; } = true;

    private void OnMediaQueryChange(bool mediaQueryMatched)
    {
        LargeScreen = DrawerExpanded = mediaQueryMatched;
    }

    private void DrawerExpandedChanged(bool newExpanded)
    {
        if (!LargeScreen && !newExpanded)
        {
            DrawerExpanded = newExpanded;
        }
    }

    private void SelectDrawerItem()
    {
        var url = NavManager.Uri.Replace(NavManager.BaseUri, "/").ToLowerInvariant();

        // Try to find in root items first
        DrawerSelectedItem = DrawerData.FirstOrDefault(x => x.Url?.ToLowerInvariant() == url);
        
        // If not found, search in children
        if (DrawerSelectedItem == null)
        {
            foreach (var item in DrawerData)
            {
                if (item.Children != null)
                {
                    DrawerSelectedItem = item.Children.FirstOrDefault(x => x.Url?.ToLowerInvariant() == url);
                    if (DrawerSelectedItem != null) break;
                    
                    // Search nested children
                    foreach (var child in item.Children)
                    {
                        if (child.Children != null)
                        {
                            DrawerSelectedItem = child.Children.FirstOrDefault(x => x.Url?.ToLowerInvariant() == url);
                            if (DrawerSelectedItem != null) break;
                        }
                    }
                }
            }
        }
    }

    private void NavManagerLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        var url = args.Location.Replace(NavManager.BaseUri, "/").ToLowerInvariant();

        // Try to find in root items first
        DrawerSelectedItem = DrawerData.FirstOrDefault(x => x.Url?.ToLowerInvariant() == url);
        
        // If not found, search in children
        if (DrawerSelectedItem == null)
        {
            foreach (var item in DrawerData)
            {
                if (item.Children != null)
                {
                    DrawerSelectedItem = item.Children.FirstOrDefault(x => x.Url?.ToLowerInvariant() == url);
                    if (DrawerSelectedItem != null) break;
                    
                    // Search nested children
                    foreach (var child in item.Children)
                    {
                        if (child.Children != null)
                        {
                            DrawerSelectedItem = child.Children.FirstOrDefault(x => x.Url?.ToLowerInvariant() == url);
                            if (DrawerSelectedItem != null) break;
                        }
                    }
                }
            }
        }

        InvokeAsync(StateHasChanged);
    }

    protected override void OnInitialized()
    {
        SelectDrawerItem();

        NavManager.LocationChanged += NavManagerLocationChanged;

        base.OnInitialized();
    }

    public void Dispose()
    {
        if (NavManager != null)
        {
            NavManager.LocationChanged -= NavManagerLocationChanged;
        }
    }

    public class NavItem
    {
        public string Text { get; set; }
        public object? Icon { get; set; }
        public string? Url { get; set; } = string.Empty;
        public List<NavItem>? Children { get; set; }

        public NavItem(string text, object? icon, string? url, List<NavItem>? children = null)
        {
            Text = text;
            Icon = icon;
            Url = url;
            Children = children;
        }
    }
}
