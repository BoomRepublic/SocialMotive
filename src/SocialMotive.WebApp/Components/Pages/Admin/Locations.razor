@page "/admin/locations"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api

<PageTitle>Admin - Locations</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>Locations</h1>
        <p class="text-muted">View tracker location history</p>
    </div>

    <TelerikGrid Data="@_items"
                 Pageable="true"
                 PageSize="50"
                 Sortable="true"
                 FilterMode="@GridFilterMode.FilterRow">
        <GridColumns>
            <GridColumn Field="@nameof(Location.LocationId)" Title="ID" Width="100px" />
            <GridColumn Field="@nameof(Location.TrackerId)" Title="Tracker ID" Width="110px" />
            <GridColumn Field="@nameof(Location.Latitude)" Title="Lat" Width="110px" />
            <GridColumn Field="@nameof(Location.Longitude)" Title="Lon" Width="110px" />
            <GridColumn Field="@nameof(Location.AccuracyMeters)" Title="Accuracy (m)" Width="130px" />
            <GridColumn Field="@nameof(Location.SpeedKmh)" Title="Speed (km/h)" Width="130px" />
            <GridColumn Field="@nameof(Location.Timestamp)" Title="Timestamp" DisplayFormat="{0:g}" Width="160px" />
            <GridColumn Field="@nameof(Location.CreatedAt)" Title="Created" DisplayFormat="{0:g}" Width="160px" />
        </GridColumns>
    </TelerikGrid>
</div>

@code {
    private List<Location> _items = new();

    protected override async Task OnInitializedAsync()
    {
        _items = await Api.GetLocationsAsync();
    }
}
