@page "/admin/setting/{SettingId:int}"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api
@inject NavigationManager Navigation

<PageTitle>Admin - @PageMode Setting</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>@PageMode Setting</h1>
        <p class="text-muted">@(IsCreateMode ? "Create a new setting" : $"Setting ID: {SettingId}")</p>
    </div>

    @if (_item == null)
    {
        <TelerikLoaderContainer Visible="true" Text="Loading setting..." />
    }
    else
    {
        <TelerikForm Model="@_item"
                     OnValidSubmit="@HandleValidSubmit"
                     ValidationMessageType="@FormValidationMessageType.Tooltip">
            <FormItems>
                <FormItem ColSpan="2">
                    <Template>
                        <div class="field-grid">
                            <label class="field-label">Key</label>
                            <TelerikTextBox @bind-Value="@_item.SettingKey" />

                            <label class="field-label">Value</label>
                            <TelerikTextBox @bind-Value="@_item.SettingValue" />

                            <label class="field-label">Scope</label>
                            <TelerikTextBox @bind-Value="@_item.Scope" />
                        </div>
                    </Template>
                </FormItem>
            </FormItems>
            <FormButtons>
                <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary" ButtonType="@ButtonType.Submit">Save</TelerikButton>
                <TelerikButton ButtonType="@ButtonType.Button" OnClick="@(() => Navigation.NavigateTo("/admin/settings"))">Cancel</TelerikButton>
            </FormButtons>
        </TelerikForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="k-messagebox k-messagebox-error k-mt-4">@_errorMessage</div>
        }
    }
</div>

@code {
    [Parameter] public int SettingId { get; set; }

    private global::SocialMotive.Core.Model.Admin.Setting? _item;
    private string? _errorMessage;
    private bool IsCreateMode => SettingId == 0;
    private string PageMode => IsCreateMode ? "Create" : "Edit";

    protected override async Task OnInitializedAsync()
    {
        if (IsCreateMode)
        {
            _item = new global::SocialMotive.Core.Model.Admin.Setting();
            return;
        }

        _item = await Api.GetSettingAsync(SettingId);
    }

    private async Task HandleValidSubmit()
    {
        if (_item == null) return;

        global::SocialMotive.Core.Model.Admin.Setting? result;
        if (IsCreateMode)
            result = await Api.CreateSettingAsync(_item);
        else
            result = await Api.UpdateSettingAsync(SettingId, _item);

        if (result != null)
            Navigation.NavigateTo("/admin/settings");
        else
            _errorMessage = "Failed to save setting. Please try again.";
    }
}

<style>
    .field-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 0.75rem 1rem;
        align-items: center;
    }

    .field-label {
        font-weight: 600;
    }
</style>
