@page "/admin/invite/{InviteId:int}"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api
@inject NavigationManager Navigation

<PageTitle>Admin - @PageMode Invite</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>@PageMode Invite</h1>
        <p class="text-muted">@(IsCreateMode ? "Create a new invite" : $"Invite ID: {InviteId}")</p>
    </div>

    @if (_item == null)
    {
        <TelerikLoaderContainer Visible="true" Text="Loading invite..." />
    }
    else
    {
        <TelerikForm Model="@_item"
                     OnValidSubmit="@HandleValidSubmit"
                     ValidationMessageType="@FormValidationMessageType.Tooltip">
            <FormItems>
                <FormItem ColSpan="2">
                    <Template>
                        <div class="field-grid">
                            <label class="field-label">Name</label>
                            <TelerikTextBox @bind-Value="@_item.Name" />

                            <label class="field-label">Description</label>
                            <TelerikTextBox @bind-Value="@_item.Description" />

                            <label class="field-label">Notes</label>
                            <TelerikTextBox @bind-Value="@_item.Notes" />

                            <label class="field-label">Invite Type</label>
                            <TelerikTextBox @bind-Value="@_item.InviteType" />

                            <label class="field-label">Created By Tracker ID</label>
                            <TelerikNumericTextBox @bind-Value="@_item.CreatedByTrackerId" />

                            <label class="field-label">Claimed By Tracker ID</label>
                            <TelerikNumericTextBox @bind-Value="@_item.ClaimedByTrackerId" />
                        </div>
                    </Template>
                </FormItem>
            </FormItems>
            <FormButtons>
                <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary" ButtonType="@ButtonType.Submit">Save</TelerikButton>
                <TelerikButton ButtonType="@ButtonType.Button" OnClick="@(() => Navigation.NavigateTo("/admin/invites"))">Cancel</TelerikButton>
            </FormButtons>
        </TelerikForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="k-messagebox k-messagebox-error k-mt-4">@_errorMessage</div>
        }
    }
</div>

@code {
    [Parameter] public int InviteId { get; set; }

    private global::SocialMotive.Core.Model.Admin.Invite? _item;
    private string? _errorMessage;
    private bool IsCreateMode => InviteId == 0;
    private string PageMode => IsCreateMode ? "Create" : "Edit";

    protected override async Task OnInitializedAsync()
    {
        if (IsCreateMode)
        {
            _item = new global::SocialMotive.Core.Model.Admin.Invite();
            return;
        }

        _item = await Api.GetInviteAsync(InviteId);
    }

    private async Task HandleValidSubmit()
    {
        if (_item == null) return;

        global::SocialMotive.Core.Model.Admin.Invite? result;
        if (IsCreateMode)
            result = await Api.CreateInviteAsync(_item);
        else
            result = await Api.UpdateInviteAsync(InviteId, _item);

        if (result != null)
            Navigation.NavigateTo("/admin/invites");
        else
            _errorMessage = "Failed to save invite. Please try again.";
    }
}

<style>
    .field-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 0.75rem 1rem;
        align-items: center;
    }

    .field-label {
        font-weight: 600;
    }
</style>
