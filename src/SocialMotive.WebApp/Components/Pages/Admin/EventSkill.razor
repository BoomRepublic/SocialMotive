@page "/admin/event-skill/{EventSkillId:int}"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@using AdminEventSkill = SocialMotive.Core.Model.Admin.EventSkill
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api
@inject NavigationManager Navigation

<PageTitle>Admin - @PageMode Event Skill</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>@PageMode Event Skill</h1>
        <p class="text-muted">@(IsCreateMode ? "Create a new event skill" : $"Event Skill ID: {EventSkillId}")</p>
    </div>

    @if (_item == null)
    {
        <TelerikLoaderContainer Visible="true" Text="Loading event skill..." />
    }
    else
    {
        <TelerikForm Model="@_item"
                     OnValidSubmit="@HandleValidSubmit"
                     ValidationMessageType="@FormValidationMessageType.Tooltip">
            <FormItems>
                <FormItem ColSpan="2">
                    <Template>
                        <div class="field-grid">
                            <label class="field-label">Name</label>
                            <TelerikTextBox @bind-Value="@_item.Name" />

                            <label class="field-label">Difficulty</label>
                            <TelerikNumericTextBox @bind-Value="@_item.Difficulty" />

                            <label class="field-label">Color</label>
                            <TelerikColorPicker @bind-Value="@_item.ColorHex" />

                            <label class="field-label">BG Color</label>
                            <TelerikColorPicker @bind-Value="@_item.BgColorHex" />
                        </div>
                    </Template>
                </FormItem>
            </FormItems>
            <FormButtons>
                <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary" ButtonType="@ButtonType.Submit">Save</TelerikButton>
                <TelerikButton ButtonType="@ButtonType.Button" OnClick="@(() => Navigation.NavigateTo("/admin/event-skills"))">Cancel</TelerikButton>
            </FormButtons>
        </TelerikForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="k-messagebox k-messagebox-error k-mt-4">@_errorMessage</div>
        }
    }
</div>

@code {
    [Parameter] public int EventSkillId { get; set; }

    private AdminEventSkill? _item;
    private string? _errorMessage;
    private bool IsCreateMode => EventSkillId == 0;
    private string PageMode => IsCreateMode ? "Create" : "Edit";

    protected override async Task OnInitializedAsync()
    {
        if (IsCreateMode)
        {
            _item = new AdminEventSkill();
            return;
        }

        _item = await Api.GetEventSkillAsync(EventSkillId);
    }

    private async Task HandleValidSubmit()
    {
        if (_item == null) return;

        AdminEventSkill? result;
        if (IsCreateMode)
            result = await Api.CreateEventSkillAsync(_item);
        else
            result = await Api.UpdateEventSkillAsync(EventSkillId, _item);

        if (result != null)
            Navigation.NavigateTo("/admin/event-skills");
        else
            _errorMessage = "Failed to save event skill. Please try again.";
    }
}

<style>
    .field-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 0.75rem 1rem;
        align-items: center;
    }

    .field-label {
        font-weight: 600;
    }
</style>
