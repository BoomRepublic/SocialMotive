@page "/admin/event-types"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@using AdminEventType = SocialMotive.Core.Model.Admin.EventType
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api

<PageTitle>Admin - Event Types</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>Event Types</h1>
        <p class="text-muted">Manage event type categories</p>
    </div>

    <TelerikGrid Data="@_items"
                 OnDelete="@OnDelete"
                 Pageable="true"
                 PageSize="25"
                 Sortable="true"
                 FilterMode="@GridFilterMode.FilterRow">
        <GridToolBarTemplate>
            <a href="/admin/event-type/0" class="k-button k-button-md k-rounded-md k-button-solid k-button-solid-primary">
                New Event Type
            </a>
        </GridToolBarTemplate>
        <GridColumns>
            <GridColumn Field="@nameof(AdminEventType.EventTypeId)" Title="ID" Width="80px" Editable="false" />
            <GridColumn Field="@nameof(AdminEventType.Name)" Title="Name" />
            <GridColumn Field="@nameof(AdminEventType.Description)" Title="Description" />
            <GridColumn Field="@nameof(AdminEventType.Icon)" Title="Icon" Width="120px" />
            <GridColumn Field="@nameof(AdminEventType.Color)" Title="Color" Width="100px" />
            <GridColumn Field="@nameof(AdminEventType.Created)" Title="Created" DisplayFormat="{0:d}" Width="120px" Editable="false" />
            <GridColumn Title="Edit" Width="100px" Sortable="false" Filterable="false">
                <Template Context="rowItem">
                    @{
                        var item = (AdminEventType)rowItem;
                    }
                    <a href="@($"/admin/event-type/{item.EventTypeId}")" class="k-button k-button-md k-rounded-md k-button-solid k-button-solid-base">
                        Edit
                    </a>
                </Template>
            </GridColumn>
            <GridCommandColumn Width="60px">
                <GridCommandButton Command="Delete" Icon="@SvgIcon.Trash" ThemeColor="@ThemeConstants.Button.ThemeColor.Error" />
            </GridCommandColumn>
        </GridColumns>
    </TelerikGrid>
</div>

@code {
    private List<AdminEventType> _items = new();

    protected override async Task OnInitializedAsync()
    {
        _items = await Api.GetEventTypesAsync();
    }

    private async Task OnDelete(GridCommandEventArgs args)
    {
        var item = (AdminEventType)args.Item;
        await Api.DeleteEventTypeAsync(item.EventTypeId);
        _items = await Api.GetEventTypesAsync();
    }
}
