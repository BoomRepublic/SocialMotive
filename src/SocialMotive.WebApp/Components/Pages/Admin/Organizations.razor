@page "/admin/organizations"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@using AdminOrganization = SocialMotive.Core.Model.Admin.Organization
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api

<PageTitle>Admin - Organizations</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>Organizations</h1>
        <p class="text-muted">Manage organizations</p>
    </div>

    <TelerikGrid Data="@_items"
                 OnDelete="@OnDelete"
                 Pageable="true"
                 PageSize="25"
                 Sortable="true"
                 FilterMode="@GridFilterMode.FilterRow">
        <GridToolBarTemplate>
            <a href="/admin/organization/0" class="k-button k-button-md k-rounded-md k-button-solid k-button-solid-primary">
                New Organization
            </a>
        </GridToolBarTemplate>
        <GridColumns>
            <GridColumn Field="@nameof(AdminOrganization.OrganizationId)" Title="ID" Width="80px" />
            <GridColumn Field="@nameof(AdminOrganization.Name)" Title="Name" />
            <GridColumn Field="@nameof(AdminOrganization.OwnedBy)" Title="Owned By" Width="120px" />
            <GridColumn Field="@nameof(AdminOrganization.CreatedBy)" Title="Created By" Width="120px" />
            <GridColumn Field="@nameof(AdminOrganization.CreatedAt)" Title="Created" DisplayFormat="{0:d}" Width="120px" />
            <GridColumn Title="Edit" Width="100px" Sortable="false" Filterable="false">
                <Template Context="rowItem">
                    @{ var item = (AdminOrganization)rowItem; }
                    <a href="@($"/admin/organization/{item.OrganizationId}")" class="k-button k-button-md k-rounded-md k-button-solid k-button-solid-base">Edit</a>
                </Template>
            </GridColumn>
            <GridCommandColumn Width="60px">
                <GridCommandButton Command="Delete" Icon="@SvgIcon.Trash" ThemeColor="@ThemeConstants.Button.ThemeColor.Error" />
            </GridCommandColumn>
        </GridColumns>
    </TelerikGrid>
</div>

@code {
    private List<AdminOrganization> _items = new();

    protected override async Task OnInitializedAsync()
    {
        _items = await Api.GetOrganizationsAsync();
    }

    private async Task OnDelete(GridCommandEventArgs args)
    {
        var item = (AdminOrganization)args.Item;
        await Api.DeleteOrganizationAsync(item.OrganizationId);
        _items = await Api.GetOrganizationsAsync();
    }
}
