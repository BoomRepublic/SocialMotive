@page "/admin/generator/templates"
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Generator Templates</h2>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-primary">New Template</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Size</th>
                    <th>Published</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Template rows will be populated here -->
                <tr>
                    <td colspan="7" class="text-center text-muted">Loading templates...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@code {
    // Component logic will be added here
}
