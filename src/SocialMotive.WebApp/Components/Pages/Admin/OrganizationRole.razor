@page "/admin/organization-role/{OrganizationRoleId:int}"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@using AdminOrganizationRole = SocialMotive.Core.Model.Admin.OrganizationRole
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api
@inject NavigationManager Navigation

<PageTitle>Admin - @PageMode Organization Role</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>@PageMode Organization Role</h1>
        <p class="text-muted">@(IsCreateMode ? "Create a new organization role" : $"Organization Role ID: {OrganizationRoleId}")</p>
    </div>

    @if (_item == null)
    {
        <TelerikLoaderContainer Visible="true" Text="Loading organization role..." />
    }
    else
    {
        <TelerikForm Model="@_item"
                     OnValidSubmit="@HandleValidSubmit"
                     ValidationMessageType="@FormValidationMessageType.Tooltip">
            <FormItems>
                <FormItem ColSpan="2">
                    <Template>
                        <div class="field-grid">
                            <label class="field-label">Name</label>
                            <TelerikTextBox @bind-Value="@_item.Name" />

                            <label class="field-label">Color Hex</label>
                            <TelerikColorPicker @bind-Value="@_item.ColorHex" />

                            <label class="field-label">BG Color Hex</label>
                            <TelerikColorPicker @bind-Value="@_item.BgColorHex" />
                        </div>
                    </Template>
                </FormItem>
            </FormItems>
            <FormButtons>
                <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary" ButtonType="@ButtonType.Submit">Save</TelerikButton>
                <TelerikButton ButtonType="@ButtonType.Button" OnClick="@(() => Navigation.NavigateTo("/admin/organization-roles"))">Cancel</TelerikButton>
            </FormButtons>
        </TelerikForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="k-messagebox k-messagebox-error k-mt-4">@_errorMessage</div>
        }
    }
</div>

@code {
    [Parameter] public int OrganizationRoleId { get; set; }

    private AdminOrganizationRole? _item;
    private string? _errorMessage;
    private bool IsCreateMode => OrganizationRoleId == 0;
    private string PageMode => IsCreateMode ? "Create" : "Edit";

    protected override async Task OnInitializedAsync()
    {
        if (IsCreateMode)
        {
            _item = new AdminOrganizationRole();
            return;
        }

        _item = await Api.GetOrganizationRoleAsync(OrganizationRoleId);
    }

    private async Task HandleValidSubmit()
    {
        if (_item == null) return;

        AdminOrganizationRole? result;
        if (IsCreateMode)
            result = await Api.CreateOrganizationRoleAsync(_item);
        else
            result = await Api.UpdateOrganizationRoleAsync(OrganizationRoleId, _item);

        if (result != null)
            Navigation.NavigateTo("/admin/organization-roles");
        else
            _errorMessage = "Failed to save organization role. Please try again.";
    }
}

<style>
    .field-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 0.75rem 1rem;
        align-items: center;
    }

    .field-label {
        font-weight: 600;
    }
</style>
