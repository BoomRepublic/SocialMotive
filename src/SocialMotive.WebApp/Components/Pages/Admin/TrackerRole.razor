@page "/admin/tracker-role/{TrackerRoleId:int}"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api
@inject NavigationManager Navigation

<PageTitle>Admin - @PageMode Tracker Role</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>@PageMode Tracker Role</h1>
        <p class="text-muted">@(IsCreateMode ? "Create a new tracker role" : $"Role ID: {TrackerRoleId}")</p>
    </div>

    @if (_item == null)
    {
        <TelerikLoaderContainer Visible="true" Text="Loading tracker role..." />
    }
    else
    {
        <TelerikForm Model="@_item"
                     OnValidSubmit="@HandleValidSubmit"
                     ValidationMessageType="@FormValidationMessageType.Tooltip">
            <FormItems>
                <FormItem ColSpan="2">
                    <Template>
                        <div class="field-grid">
                            <label class="field-label">Name</label>
                            <TelerikTextBox @bind-Value="@_item.Name" />

                            <label class="field-label">Description</label>
                            <TelerikTextBox @bind-Value="@_item.Description" />
                        </div>
                    </Template>
                </FormItem>
            </FormItems>
            <FormButtons>
                <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary" ButtonType="@ButtonType.Submit">Save</TelerikButton>
                <TelerikButton ButtonType="@ButtonType.Button" OnClick="@(() => Navigation.NavigateTo("/admin/tracker-roles"))">Cancel</TelerikButton>
            </FormButtons>
        </TelerikForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="k-messagebox k-messagebox-error k-mt-4">@_errorMessage</div>
        }
    }
</div>

@code {
    [Parameter] public int TrackerRoleId { get; set; }

    private global::SocialMotive.Core.Model.Admin.TrackerRole? _item;
    private string? _errorMessage;
    private bool IsCreateMode => TrackerRoleId == 0;
    private string PageMode => IsCreateMode ? "Create" : "Edit";

    protected override async Task OnInitializedAsync()
    {
        if (IsCreateMode)
        {
            _item = new global::SocialMotive.Core.Model.Admin.TrackerRole();
            return;
        }

        _item = await Api.GetTrackerRoleAsync(TrackerRoleId);
    }

    private async Task HandleValidSubmit()
    {
        if (_item == null) return;

        global::SocialMotive.Core.Model.Admin.TrackerRole? result;
        if (IsCreateMode)
            result = await Api.CreateTrackerRoleAsync(_item);
        else
            result = await Api.UpdateTrackerRoleAsync(TrackerRoleId, _item);

        if (result != null)
            Navigation.NavigateTo("/admin/tracker-roles");
        else
            _errorMessage = "Failed to save tracker role. Please try again.";
    }
}

<style>
    .field-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 0.75rem 1rem;
        align-items: center;
    }

    .field-label {
        font-weight: 600;
    }
</style>
