@page "/admin/city/{CityId:int}"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@using AdminCity = global::SocialMotive.Core.Model.Admin.City
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api
@inject NavigationManager Navigation

<PageTitle>Admin - @PageMode City</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>@PageMode City</h1>
        <p class="text-muted">@(IsCreateMode ? "Create a new city" : $"City ID: {CityId}")</p>
    </div>

    @if (_item == null)
    {
        <TelerikLoaderContainer Visible="true" Text="Loading city..." />
    }
    else
    {
        <TelerikForm Model="@_item"
                     OnValidSubmit="@HandleValidSubmit"
                     ValidationMessageType="@FormValidationMessageType.Tooltip">
            <FormItems>
                <FormItem ColSpan="2">
                    <Template>
                        <div class="field-grid">
                            <label class="field-label">Name</label>
                            <TelerikTextBox @bind-Value="@_item.Name" />

                            <label class="field-label">Code</label>
                            <TelerikTextBox @bind-Value="@_item.Code" />

                            <label class="field-label">Code GM</label>
                            <TelerikTextBox @bind-Value="@_item.CodeGm" />

                            <label class="field-label">Province</label>
                            <TelerikTextBox @bind-Value="@_item.ProvincieNaam" />

                            <label class="field-label">Province Code</label>
                            <TelerikTextBox @bind-Value="@_item.ProvincieCode" />

                            <label class="field-label">Province Code PV</label>
                            <TelerikTextBox @bind-Value="@_item.ProvincieCodePv" />

                            <label class="field-label">Latitude</label>
                            <TelerikNumericTextBox @bind-Value="@_item.Latitude" />

                            <label class="field-label">Longitude</label>
                            <TelerikNumericTextBox @bind-Value="@_item.Longitude" />
                        </div>
                    </Template>
                </FormItem>
            </FormItems>
            <FormButtons>
                <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary" ButtonType="@ButtonType.Submit">Save</TelerikButton>
                <TelerikButton ButtonType="@ButtonType.Button" OnClick="@(() => Navigation.NavigateTo("/admin/cities"))">Cancel</TelerikButton>
            </FormButtons>
        </TelerikForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="k-messagebox k-messagebox-error k-mt-4">@_errorMessage</div>
        }
    }
</div>

@code {
    [Parameter] public int CityId { get; set; }

    private AdminCity? _item;
    private string? _errorMessage;
    private bool IsCreateMode => CityId == 0;
    private string PageMode => IsCreateMode ? "Create" : "Edit";

    protected override async Task OnInitializedAsync()
    {
        if (IsCreateMode)
        {
            _item = new AdminCity();
            return;
        }

        _item = await Api.GetCityAsync(CityId);
    }

    private async Task HandleValidSubmit()
    {
        if (_item == null) return;

        AdminCity? result;
        if (IsCreateMode)
            result = await Api.CreateCityAsync(_item);
        else
            result = await Api.UpdateCityAsync(CityId, _item);

        if (result != null)
            Navigation.NavigateTo("/admin/cities");
        else
            _errorMessage = "Failed to save city. Please try again.";
    }
}

<style>
    .field-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 0.75rem 1rem;
        align-items: center;
    }

    .field-label {
        font-weight: 600;
    }
</style>
