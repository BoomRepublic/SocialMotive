@page "/admin/organization-roles"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@using AdminOrganizationRole = SocialMotive.Core.Model.Admin.OrganizationRole
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api

<PageTitle>Admin - Organization Roles</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>Organization Roles</h1>
        <p class="text-muted">Manage organization roles</p>
    </div>

    <TelerikGrid Data="@_items"
                 OnDelete="@OnDelete"
                 Pageable="true"
                 PageSize="25"
                 Sortable="true"
                 FilterMode="@GridFilterMode.FilterRow">
        <GridToolBarTemplate>
            <a href="/admin/organization-role/0" class="k-button k-button-md k-rounded-md k-button-solid k-button-solid-primary">
                New Organization Role
            </a>
        </GridToolBarTemplate>
        <GridColumns>
            <GridColumn Field="@nameof(AdminOrganizationRole.OrganizationRoleId)" Title="ID" Width="80px" />
            <GridColumn Field="@nameof(AdminOrganizationRole.Name)" Title="Name" />
            <GridColumn Field="@nameof(AdminOrganizationRole.ColorHex)" Title="Color" Width="120px" />
            <GridColumn Field="@nameof(AdminOrganizationRole.BgColorHex)" Title="BG Color" Width="120px" />
            <GridColumn Title="Edit" Width="100px" Sortable="false" Filterable="false">
                <Template Context="rowItem">
                    @{ var item = (AdminOrganizationRole)rowItem; }
                    <a href="@($"/admin/organization-role/{item.OrganizationRoleId}")" class="k-button k-button-md k-rounded-md k-button-solid k-button-solid-base">Edit</a>
                </Template>
            </GridColumn>
            <GridCommandColumn Width="60px">
                <GridCommandButton Command="Delete" Icon="@SvgIcon.Trash" ThemeColor="@ThemeConstants.Button.ThemeColor.Error" />
            </GridCommandColumn>
        </GridColumns>
    </TelerikGrid>
</div>

@code {
    private List<AdminOrganizationRole> _items = new();

    protected override async Task OnInitializedAsync()
    {
        _items = await Api.GetOrganizationRolesAsync();
    }

    private async Task OnDelete(GridCommandEventArgs args)
    {
        var item = (AdminOrganizationRole)args.Item;
        await Api.DeleteOrganizationRoleAsync(item.OrganizationRoleId);
        _items = await Api.GetOrganizationRolesAsync();
    }
}
