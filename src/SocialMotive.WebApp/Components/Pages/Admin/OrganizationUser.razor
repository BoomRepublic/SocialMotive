@page "/admin/organization-user/{OrganizationUserId:int}"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@using AdminOrganizationUser = SocialMotive.Core.Model.Admin.OrganizationUser
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api
@inject NavigationManager Navigation

<PageTitle>Admin - @PageMode Organization User</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>@PageMode Organization User</h1>
        <p class="text-muted">@(IsCreateMode ? "Create a new organization user" : $"Organization User ID: {OrganizationUserId}")</p>
    </div>

    @if (_item == null)
    {
        <TelerikLoaderContainer Visible="true" Text="Loading organization user..." />
    }
    else
    {
        <TelerikForm Model="@_item"
                     OnValidSubmit="@HandleValidSubmit"
                     ValidationMessageType="@FormValidationMessageType.Tooltip">
            <FormItems>
                <FormItem ColSpan="2">
                    <Template>
                        <div class="field-grid">
                            <label class="field-label">User ID</label>
                            <TelerikNumericTextBox @bind-Value="@_item.UserId" />

                            <label class="field-label">Organization Role ID</label>
                            <TelerikNumericTextBox @bind-Value="@_item.OrganizationRoleId" />

                            <label class="field-label">Assigned By (User ID)</label>
                            <TelerikNumericTextBox @bind-Value="@_item.AssignedBy" />
                        </div>
                    </Template>
                </FormItem>
            </FormItems>
            <FormButtons>
                <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary" ButtonType="@ButtonType.Submit">Save</TelerikButton>
                <TelerikButton ButtonType="@ButtonType.Button" OnClick="@(() => Navigation.NavigateTo("/admin/organization-users"))">Cancel</TelerikButton>
            </FormButtons>
        </TelerikForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="k-messagebox k-messagebox-error k-mt-4">@_errorMessage</div>
        }
    }
</div>

@code {
    [Parameter] public int OrganizationUserId { get; set; }

    private AdminOrganizationUser? _item;
    private string? _errorMessage;
    private bool IsCreateMode => OrganizationUserId == 0;
    private string PageMode => IsCreateMode ? "Create" : "Edit";

    protected override async Task OnInitializedAsync()
    {
        if (IsCreateMode)
        {
            _item = new AdminOrganizationUser();
            return;
        }

        _item = await Api.GetOrganizationUserAsync(OrganizationUserId);
    }

    private async Task HandleValidSubmit()
    {
        if (_item == null) return;

        AdminOrganizationUser? result;
        if (IsCreateMode)
            result = await Api.CreateOrganizationUserAsync(_item);
        else
            result = await Api.UpdateOrganizationUserAsync(OrganizationUserId, _item);

        if (result != null)
            Navigation.NavigateTo("/admin/organization-users");
        else
            _errorMessage = "Failed to save organization user. Please try again.";
    }
}

<style>
    .field-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 0.75rem 1rem;
        align-items: center;
    }

    .field-label {
        font-weight: 600;
    }
</style>
