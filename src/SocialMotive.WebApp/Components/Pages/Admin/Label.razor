@page "/admin/label/{LabelId:int}"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@using AdminLabel = SocialMotive.Core.Model.Admin.Label
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api
@inject NavigationManager Navigation

<PageTitle>Admin - @PageMode Label</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>@PageMode Label</h1>
        <p class="text-muted">@(IsCreateMode ? "Create a new label" : $"Label ID: {LabelId}")</p>
    </div>

    @if (_item == null)
    {
        <TelerikLoaderContainer Visible="true" Text="Loading label..." />
    }
    else
    {
        <TelerikForm Model="@_item"
                     OnValidSubmit="@HandleValidSubmit"
                     ValidationMessageType="@FormValidationMessageType.Tooltip">
            <FormItems>
                <FormItem ColSpan="2">
                    <Template>
                        <div class="field-grid">
                            <label class="field-label">Name</label>
                            <TelerikTextBox @bind-Value="@_item.Name" />

                            <label class="field-label">Color</label>
                            <TelerikColorPicker @bind-Value="@_item.ColorHex" />

                            <label class="field-label">Icon</label>
                            <TelerikTextBox @bind-Value="@_item.IconType" />

                            <label class="field-label">Type</label>
                            <TelerikTextBox @bind-Value="@_item.LabelType" />

                            <label class="field-label">Level</label>
                            <TelerikNumericTextBox @bind-Value="@_item.Level" />

                            <label class="field-label">Published</label>
                            <TelerikCheckBox @bind-Value="@_item.Publish" />
                        </div>
                    </Template>
                </FormItem>
            </FormItems>
            <FormButtons>
                <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary" ButtonType="@ButtonType.Submit">Save</TelerikButton>
                <TelerikButton ButtonType="@ButtonType.Button" OnClick="@(() => Navigation.NavigateTo("/admin/labels"))">Cancel</TelerikButton>
            </FormButtons>
        </TelerikForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="k-messagebox k-messagebox-error k-mt-4">@_errorMessage</div>
        }
    }
</div>

@code {
    [Parameter] public int LabelId { get; set; }

    private AdminLabel? _item;
    private string? _errorMessage;
    private bool IsCreateMode => LabelId == 0;
    private string PageMode => IsCreateMode ? "Create" : "Edit";

    protected override async Task OnInitializedAsync()
    {
        if (IsCreateMode)
        {
            _item = new AdminLabel();
            return;
        }

        _item = await Api.GetLabelAsync(LabelId);
    }

    private async Task HandleValidSubmit()
    {
        if (_item == null) return;

        AdminLabel? result;
        if (IsCreateMode)
            result = await Api.CreateLabelAsync(_item);
        else
            result = await Api.UpdateLabelAsync(LabelId, _item);

        if (result != null)
            Navigation.NavigateTo("/admin/labels");
        else
            _errorMessage = "Failed to save label. Please try again.";
    }
}

<style>
    .field-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 0.75rem 1rem;
        align-items: center;
    }

    .field-label {
        font-weight: 600;
    }
</style>
