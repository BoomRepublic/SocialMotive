@page "/admin/cities"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using SocialMotive.Core.Model.Admin
@using AdminCity = SocialMotive.Core.Model.Admin.City
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiService Api

<PageTitle>Admin - Cities</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1>Cities</h1>
        <p class="text-muted">Manage city records</p>
    </div>

    <TelerikGrid Data="@_items"
                 OnDelete="@OnDelete"
                 Pageable="true"
                 PageSize="25"
                 Sortable="true"
                 FilterMode="@GridFilterMode.FilterRow">
        <GridToolBarTemplate>
            <a href="/admin/city/0" class="k-button k-button-md k-rounded-md k-button-solid k-button-solid-primary">
                New City
            </a>
        </GridToolBarTemplate>
        <GridColumns>
            <GridColumn Field="@nameof(AdminCity.CityId)" Title="ID" Width="80px" />
            <GridColumn Field="@nameof(AdminCity.Name)" Title="Name" />
            <GridColumn Field="@nameof(AdminCity.Code)" Title="Code" Width="100px" />
            <GridColumn Field="@nameof(AdminCity.ProvincieNaam)" Title="Province" />
            <GridColumn Field="@nameof(AdminCity.ProvincieCode)" Title="Province Code" Width="130px" />
            <GridColumn Field="@nameof(AdminCity.Latitude)" Title="Lat" Width="100px" />
            <GridColumn Field="@nameof(AdminCity.Longitude)" Title="Lon" Width="100px" />
            <GridColumn Title="Edit" Width="100px" Sortable="false" Filterable="false">
                <Template Context="rowItem">
                    @{ var item = (AdminCity)rowItem; }
                    <a href="@($"/admin/city/{item.CityId}")" class="k-button k-button-md k-rounded-md k-button-solid k-button-solid-base">Edit</a>
                </Template>
            </GridColumn>
            <GridCommandColumn Width="60px">
                <GridCommandButton Command="Delete" Icon="@SvgIcon.Trash" ThemeColor="@ThemeConstants.Button.ThemeColor.Error" />
            </GridCommandColumn>
        </GridColumns>
    </TelerikGrid>
</div>

@code {
    private List<AdminCity> _items = new();

    protected override async Task OnInitializedAsync()
    {
        _items = await Api.GetCitiesAsync();
    }

    private async Task OnDelete(GridCommandEventArgs args)
    {
        var item = (AdminCity)args.Item;
        await Api.DeleteCityAsync(item.CityId);
        _items = await Api.GetCitiesAsync();
    }
}
