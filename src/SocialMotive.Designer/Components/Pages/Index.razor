@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@implements IAsyncDisposable
@using System.Security.Claims
@using System.Globalization
@using System.Text
@using System.Text.Json
@using System.Text.Json.Nodes
@using AutoMapper
@using AutoMapper.QueryableExtensions
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using SocialMotive.Core.Data
@using SocialMotive.Core.Data.Generator
@using SocialMotive.Core.Generator
@using SocialMotive.Core.Model.Generator
@using Telerik.Blazor
@inject IDbContextFactory<SocialMotiveDbContext> DbFactory
@inject IDesignService DesignService
@inject IMapper Mapper
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Designer</PageTitle>

<div class="designer-page">

    @* ── Toolbar ─────────────────────────────────────────────────── *@
    <div class="designer-toolbar">
        <div class="designer-toolbar-left">
            <TelerikDropDownList Data="@_templates"
                                 TItem="TemplateSummary" TValue="int"
                                 Value="@_selectedTemplateId"
                                 ValueChanged="@OnTemplateChangedAsync"
                                 TextField="@nameof(TemplateSummary.Name)"
                                 ValueField="@nameof(TemplateSummary.TemplateId)"
                                 DefaultText="Select template…"
                                 Width="220px" />
            <TelerikButton OnClick="@ShowNewTemplateDialog"
                           ThemeColor="@ThemeConstants.Button.ThemeColor.Primary">
                New
            </TelerikButton>
            <TelerikButton OnClick="@DeleteTemplateAsync"
                           Enabled="@(_template != null)"
                           ThemeColor="@ThemeConstants.Button.ThemeColor.Error">
                Delete
            </TelerikButton>
        </div>
        <div class="designer-toolbar-center">
            @if (_template != null)
            {
                <span class="template-info">@_template.Name — @_template.Width × @_template.Height px</span>
                <TelerikButton OnClick="@(() => _showAxisOverlay = !_showAxisOverlay)"
                               Size="@ThemeConstants.Button.Size.Small"
                               ThemeColor="@(_showAxisOverlay ? ThemeConstants.Button.ThemeColor.Info : ThemeConstants.Button.ThemeColor.Base)">
                    ┼
                </TelerikButton>
                <TelerikDropDownList Data="@_zoomLevels"
                                     TItem="ZoomLevel" TValue="string"
                                     Value="@_selectedZoom.Label"
                                     ValueChanged="@OnZoomChangedAsync"
                                     TextField="@nameof(ZoomLevel.Label)"
                                     ValueField="@nameof(ZoomLevel.Label)"
                                     Width="90px" />
            }
        </div>
        <div class="designer-toolbar-right">
            <TelerikButton OnClick="@RenderPngAsync"
                           Enabled="@(_template != null && !_isRendering)"
                           ThemeColor="@ThemeConstants.Button.ThemeColor.Success">
                @(_isRendering ? "Rendering…" : "Render PNG")
            </TelerikButton>
        </div>
    </div>

    @* ── Body ───────────────────────────────────────────────────── *@
    <div class="designer-body">
        @if (_initError != null)
        {
            <div class="designer-empty">
                <p style="color:var(--kendo-color-error,#f87171);">Could not connect to the database.</p>
                <p style="font-size:0.8rem; color:var(--kendo-color-subtle-text,#94a3b8); max-width:480px; text-align:center;">@_initError</p>
                <TelerikButton OnClick="@RetryInitAsync" ThemeColor="@ThemeConstants.Button.ThemeColor.Primary">Retry</TelerikButton>
            </div>
        }
        else if (_loading)
        {
            <div class="designer-empty">
                <p>Loading…</p>
            </div>
        }
        else if (_template == null)
        {
            <div class="designer-empty">
                <p>Select or create a template to start designing.</p>
                <TelerikButton OnClick="@ShowNewTemplateDialog"
                               ThemeColor="@ThemeConstants.Button.ThemeColor.Primary">
                    Create Template
                </TelerikButton>
            </div>
        }
        else
        {
            <TelerikSplitter Width="100%" Height="100%">
                <SplitterPanes>

                    @* ── Left: Layer list ── *@
                    <SplitterPane Size="240px" Min="160px" Collapsible="true">
                        <div class="panel-section">
                            <div class="panel-header">
                                <span>Layers</span>
                                <div class="add-layer-wrap">
                                    <TelerikButton OnClick="@(() => _showAddMenu = !_showAddMenu)"
                                                   Size="@ThemeConstants.Button.Size.Small">
                                        + Add
                                    </TelerikButton>
                                    @if (_showAddMenu)
                                    {
                                        <div class="add-layer-menu">
                                            @foreach (var lt in _layerTypes)
                                            {
                                                var layerType = lt;
                                                <div class="add-layer-item"
                                                     @onclick="@(async () => await HandleAddLayerAsync(layerType))">
                                                    @layerType
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="layer-list">
                                @{var sortedLayers = _template.Layers.OrderByDescending(l => l.ZIndex).ToList();}
                                @for (int i = 0; i < sortedLayers.Count; i++)
                                {
                                    var layer = sortedLayers[i];
                                    var idx = i;
                                    var isSelected = layer.LayerId == _selectedLayer?.LayerId;
                                    var layerVisible = SafeDeserialize<LayerSettings>(layer.SettingsJson).IsVisible;
                                    <div class="designer-layer-item @(isSelected ? "selected" : "") @(!layerVisible ? "layer-hidden" : "") @(_dragOverIndex == idx ? "drag-over" : "")"
                                         draggable="true"
                                         @ondragstart="@(() => _dragSourceIndex = idx)"
                                         @ondragend="@(() => { _dragSourceIndex = null; _dragOverIndex = null; })"
                                         @ondragover:preventDefault
                                         @ondragenter="@(() => _dragOverIndex = idx)"
                                         @ondragleave="@(() => { if (_dragOverIndex == idx) _dragOverIndex = null; })"
                                         @ondrop="@(async () => await OnLayerDropAsync(idx))"
                                         @onclick="@(() => SelectLayer(layer))">
                                        <span class="layer-type-badge">@(layer.LayerType.Length > 0 ? layer.LayerType[0..1].ToUpper() : "?")</span>
                                        <span class="layer-name">@layer.Name</span>
                                        <div class="layer-actions">
                                            <TelerikButton OnClick="@(() => ToggleLayerVisibility(layer))"
                                                           Size="@ThemeConstants.Button.Size.Small"
                                                           Title="@(layerVisible ? "Hide layer" : "Show layer")">
                                                <TelerikSvgIcon Icon="@(layerVisible ? SvgIcon.Eye : SvgIcon.EyeSlash)" />
                                            </TelerikButton>
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (_selectedLayer != null)
                            {
                                <div class="panel-footer">
                                    <TelerikButton OnClick="@DeleteLayerAsync"
                                                   ThemeColor="@ThemeConstants.Button.ThemeColor.Error"
                                                   Size="@ThemeConstants.Button.Size.Small">
                                        Delete Layer
                                    </TelerikButton>
                                </div>
                            }
                        </div>
                    </SplitterPane>

                    @* ── Center: Canvas ── *@
                    <SplitterPane>
                        <div class="designer-canvas-wrap" @ref="_canvasWrapRef">
                            @* Spacer div sized to the scaled canvas so overflow/scroll works correctly *@
                            <div style="width:@(CanvasScaledWidth)px; height:@(CanvasScaledHeight)px; position:relative; flex-shrink:0;">
                                <div class="designer-canvas" style="@CanvasContainerStyle">
                                    @foreach (var layer in _template.Layers.OrderBy(l => l.ZIndex))
                                    {
                                        var isSelected = layer.LayerId == _selectedLayer?.LayerId;
                                        var isFullBleed = layer.LayerType is "background" or "overlay";
                                        <div class="canvas-layer @(isSelected ? "canvas-layer-selected" : "")"
                                             style="@GetLayerStyle(layer)"
                                             data-layer-id="@layer.LayerId"
                                             data-fullbleed="@(isFullBleed ? "true" : "false")"
                                             @onclick="@(() => SelectLayer(layer))">
                                            @if (layer.LayerType == "text")
                                            {
                                                var ts = SafeDeserialize<TextLayerSettings>(layer.SettingsJson);
                                                <span>@ts.TextContent</span>
                                            }
                                            else if (layer.LayerType == "image")
                                            {
                                                var imgS = SafeDeserialize<ImageLayerSettings>(layer.SettingsJson);
                                                if (imgS.AssetId.HasValue)
                                                {
                                                    <img src="/api/design/assets/@imgS.AssetId/image"
                                                         style="width:100%; height:100%; object-fit:@(imgS.ObjectFit ?? "cover"); pointer-events:none;"
                                                         alt="@layer.Name" />
                                                }
                                            }
                                            @if (isSelected && !isFullBleed)
                                            {
                                                @* Resize handles *@
                                                <div class="layer-resize-handle" data-handle="nw"></div>
                                                <div class="layer-resize-handle" data-handle="n"></div>
                                                <div class="layer-resize-handle" data-handle="ne"></div>
                                                <div class="layer-resize-handle" data-handle="e"></div>
                                                <div class="layer-resize-handle" data-handle="se"></div>
                                                <div class="layer-resize-handle" data-handle="s"></div>
                                                <div class="layer-resize-handle" data-handle="sw"></div>
                                                <div class="layer-resize-handle" data-handle="w"></div>
                                                @* Rotate handle *@
                                                <div class="layer-rotate-handle"></div>
                                            }
                                        </div>
                                    }
                                    @if (_showAxisOverlay)
                                    {
                                        <svg class="canvas-axis-overlay" width="@_template.Width" height="@_template.Height">
                                            <line x1="@(_template.Width / 2)" y1="0" x2="@(_template.Width / 2)" y2="@_template.Height"
                                                  stroke="rgba(99,102,241,0.4)" stroke-width="1" stroke-dasharray="6,4" />
                                            <line x1="0" y1="@(_template.Height / 2)" x2="@_template.Width" y2="@(_template.Height / 2)"
                                                  stroke="rgba(99,102,241,0.4)" stroke-width="1" stroke-dasharray="6,4" />
                                            <text x="@(_template.Width / 2 + 4)" y="@(_template.Height / 2 - 4)"
                                                  fill="rgba(99,102,241,0.6)" font-size="11" font-family="monospace">0,0</text>
                                        </svg>
                                    }
                                </div>
                            </div>
                        </div>
                    </SplitterPane>

                    @* ── Right: Properties ── *@
                    <SplitterPane Size="300px" Min="200px" Collapsible="true" Scrollable="true">
                        @if (_selectedLayer == null)
                        {
                            <div class="panel-empty">Select a layer to edit its properties.</div>
                        }
                        else
                        {
                            <div class="panel-section" style="overflow-y:auto;">

                                @* Common *@
                                <div class="prop-group">
                                    <div class="prop-row">
                                        <label>Name</label>
                                        <TelerikTextBox @bind-Value="@_selectedLayer.Name" @bind-Value:after="SyncAndSaveLayer" Width="100%" />
                                    </div>
                                    <div class="prop-row">
                                        <label>Visible</label>
                                        <TelerikCheckBox @bind-Value="@_activeSettings.IsVisible" @bind-Value:after="SyncAndSaveLayer" />
                                    </div>
                                    <div class="prop-row">
                                        <label>Opacity</label>
                                        <TelerikSlider @bind-Value="@OpacityPercent" @bind-Value:after="SyncAndSaveLayer"
                                                       Min="0" Max="100" SmallStep="5" LargeStep="25"
                                                       Width="100%" />
                                    </div>
                                </div>

                                @* Background / Overlay *@
                                @if (_selectedLayer.LayerType is "background" or "overlay")
                                {
                                    <div class="prop-group">
                                        <div class="prop-row">
                                            <label>Color</label>
                                            <TelerikColorPicker @bind-Value="@_activeSettings.BackgroundColor" @bind-Value:after="SyncAndSaveLayer"
                                                                ValueFormat="ColorFormat.Hex" />
                                        </div>
                                    </div>
                                }

                                @* Image *@
                                @if (_activeSettings is ImageLayerSettings imgSettings)
                                {
                                    <div class="prop-group">
                                        <div class="prop-row">
                                            <label>Asset</label>
                                            <TelerikDropDownList Data="@_assets"
                                                                 TItem="Asset" TValue="int"
                                                                 Value="@(imgSettings.AssetId ?? 0)"
                                                                 ValueChanged="@((int v) => OnAssetSelected(imgSettings, v))"
                                                                 TextField="@nameof(Asset.FileName)"
                                                                 ValueField="@nameof(Asset.AssetId)"
                                                                 DefaultText="(none)"
                                                                 Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Fit</label>
                                            <TelerikDropDownList Data="@_objectFitOptions"
                                                                 @bind-Value="@imgSettings.ObjectFit" @bind-Value:after="SyncAndSaveLayer"
                                                                 Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Brightness</label>
                                            <TelerikSlider TValue="decimal"
                                                           Value="@(imgSettings.FilterBrightness ?? 100m)"
                                                           ValueChanged="@((decimal v) => { imgSettings.FilterBrightness = v; SyncAndSaveLayer(); })"
                                                           Min="0m" Max="200m" SmallStep="5m" LargeStep="50m"
                                                           Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Contrast</label>
                                            <TelerikSlider TValue="decimal"
                                                           Value="@(imgSettings.FilterContrast ?? 100m)"
                                                           ValueChanged="@((decimal v) => { imgSettings.FilterContrast = v; SyncAndSaveLayer(); })"
                                                           Min="0m" Max="200m" SmallStep="5m" LargeStep="50m"
                                                           Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Saturation</label>
                                            <TelerikSlider TValue="decimal"
                                                           Value="@(imgSettings.FilterSaturation ?? 100m)"
                                                           ValueChanged="@((decimal v) => { imgSettings.FilterSaturation = v; SyncAndSaveLayer(); })"
                                                           Min="0m" Max="200m" SmallStep="5m" LargeStep="50m"
                                                           Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Blur</label>
                                            <TelerikSlider TValue="decimal"
                                                           Value="@(imgSettings.FilterBlur ?? 0m)"
                                                           ValueChanged="@((decimal v) => { imgSettings.FilterBlur = v; SyncAndSaveLayer(); })"
                                                           Min="0m" Max="50m" SmallStep="1m" LargeStep="10m"
                                                           Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Hue Rotate</label>
                                            <TelerikSlider TValue="decimal"
                                                           Value="@(imgSettings.FilterHue ?? 0m)"
                                                           ValueChanged="@((decimal v) => { imgSettings.FilterHue = v; SyncAndSaveLayer(); })"
                                                           Min="0m" Max="360m" SmallStep="5m" LargeStep="30m"
                                                           Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Grayscale</label>
                                            <TelerikSlider TValue="decimal"
                                                           Value="@(imgSettings.FilterGrayscale ?? 0m)"
                                                           ValueChanged="@((decimal v) => { imgSettings.FilterGrayscale = v; SyncAndSaveLayer(); })"
                                                           Min="0m" Max="100m" SmallStep="5m" LargeStep="25m"
                                                           Width="100%" />
                                        </div>
                                    </div>
                                }

                                @* Text *@
                                @if (_activeSettings is TextLayerSettings txtSettings)
                                {
                                    <div class="prop-group">
                                        <div class="prop-row">
                                            <label>Text</label>
                                            <TelerikTextArea @bind-Value="@txtSettings.TextContent" @bind-Value:after="SyncAndSaveLayer"
                                                             Width="100%" Rows="4" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Color</label>
                                            <TelerikColorPicker @bind-Value="@_activeSettings.BackgroundColor" @bind-Value:after="SyncAndSaveLayer"
                                                                ValueFormat="ColorFormat.Hex" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Font</label>
                                            <TelerikDropDownList Data="@_fontFamilyOptions"
                                                                 @bind-Value="@txtSettings.FontFamily" @bind-Value:after="SyncAndSaveLayer"
                                                                 Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Size</label>
                                            <TelerikNumericTextBox @bind-Value="@txtSettings.FontSize" @bind-Value:after="SyncAndSaveLayer"
                                                                   Min="1m" Max="500m" Step="1m"
                                                                   Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Weight</label>
                                            <TelerikDropDownList Data="@_fontWeightOptions"
                                                                 @bind-Value="@txtSettings.FontWeight" @bind-Value:after="SyncAndSaveLayer"
                                                                 Width="100%" />
                                        </div>
                                    </div>
                                }

                                @* Shape *@
                                @if (_activeSettings is ShapeLayerSettings shapeSettings)
                                {
                                    <div class="prop-group">
                                        <div class="prop-row">
                                            <label>Type</label>
                                            <TelerikDropDownList Data="@_shapeTypeOptions"
                                                                 @bind-Value="@shapeSettings.ShapeType" @bind-Value:after="SyncAndSaveLayer"
                                                                 Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Fill</label>
                                            <TelerikColorPicker @bind-Value="@shapeSettings.FillColor" @bind-Value:after="SyncAndSaveLayer"
                                                                ValueFormat="ColorFormat.Hex" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Stroke</label>
                                            <TelerikColorPicker @bind-Value="@shapeSettings.StrokeColor" @bind-Value:after="SyncAndSaveLayer"
                                                                ValueFormat="ColorFormat.Hex" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Stroke W</label>
                                            <TelerikNumericTextBox @bind-Value="@shapeSettings.StrokeWidth" @bind-Value:after="SyncAndSaveLayer"
                                                                   Min="0m" Max="50m" Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Radius</label>
                                            <TelerikNumericTextBox @bind-Value="@shapeSettings.BorderRadiusTL" @bind-Value:after="SyncAndSaveLayer"
                                                                   Min="0m" Max="500m" Width="100%" />
                                        </div>
                                    </div>
                                }

                                @* Transform (center-origin: 0,0 = canvas center) *@
                                <details class="prop-details">
                                    <summary>Transform</summary>
                                    @{var tr = _activeSettings.Transform!;}
                                    <div class="prop-group">
                                        <div class="prop-row">
                                            <label>X</label>
                                            <TelerikNumericTextBox Value="@((tr.PositionX ?? 0) + (tr.Width ?? 0) / 2m - _template!.Width / 2m)"
                                                                   ValueChanged="@((decimal? v) => { tr.PositionX = (v ?? 0) + _template!.Width / 2m - (tr.Width ?? 0) / 2m; SyncAndSaveLayer(); })"
                                                                   Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Y</label>
                                            <TelerikNumericTextBox Value="@((tr.PositionY ?? 0) + (tr.Height ?? 0) / 2m - _template!.Height / 2m)"
                                                                   ValueChanged="@((decimal? v) => { tr.PositionY = (v ?? 0) + _template!.Height / 2m - (tr.Height ?? 0) / 2m; SyncAndSaveLayer(); })"
                                                                   Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Width</label>
                                            <TelerikNumericTextBox @bind-Value="@tr.Width" @bind-Value:after="SyncAndSaveLayer" Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Height</label>
                                            <TelerikNumericTextBox @bind-Value="@tr.Height" @bind-Value:after="SyncAndSaveLayer" Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Rotate</label>
                                            <TelerikNumericTextBox @bind-Value="@tr.Rotation" @bind-Value:after="SyncAndSaveLayer" Width="100%" />
                                        </div>
                                        <div class="prop-row">
                                            <label>Zoom</label>
                                            <TelerikNumericTextBox @bind-Value="@ZoomPercent" @bind-Value:after="SyncAndSaveLayer"
                                                                   Min="1" Max="1000" Step="10"
                                                                   Width="100%" />
                                        </div>
                                    </div>
                                </details>


                            </div>
                        }
                    </SplitterPane>

                </SplitterPanes>
            </TelerikSplitter>
        }
    </div>
</div>

@* ── Notifications ─────────────────────────────────────────────── *@
<TelerikNotification @ref="_notif"
                     HorizontalPosition="@NotificationHorizontalPosition.Right"
                     VerticalPosition="@NotificationVerticalPosition.Bottom" />

@* ── New Template Dialog ───────────────────────────────────────── *@
<TelerikWindow @bind-Visible="@_showNewTemplate"
               Width="360px"
               Modal="true">
    <WindowTitle>New Template</WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        <div class="prop-group">
            <div class="prop-row">
                <label>Name</label>
                <TelerikTextBox @bind-Value="@_newTemplateReq.Name" Width="100%" />
            </div>
            <div class="prop-row">
                <label>Width</label>
                <TelerikNumericTextBox @bind-Value="@_newTemplateReq.Width" Min="1" Max="8000" Width="100%" />
            </div>
            <div class="prop-row">
                <label>Height</label>
                <TelerikNumericTextBox @bind-Value="@_newTemplateReq.Height" Min="1" Max="8000" Width="100%" />
            </div>
            <div class="prop-row">
                <label>Category</label>
                <TelerikTextBox @bind-Value="@_newTemplateReq.Category" Width="100%" />
            </div>
        </div>
    </WindowContent>
    <WindowFooter>
        <TelerikButton OnClick="@CreateTemplateAsync" ThemeColor="@ThemeConstants.Button.ThemeColor.Primary">Create</TelerikButton>
        <TelerikButton OnClick="@(() => _showNewTemplate = false)">Cancel</TelerikButton>
    </WindowFooter>
</TelerikWindow>

@* ── Render Result Dialog ──────────────────────────────────────── *@
<TelerikWindow @bind-Visible="@_showRenderResult"
               Width="820px"
               Modal="true">
    <WindowTitle>Render Preview</WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        @if (_renderedPngBase64 != null)
        {
            <div style="overflow:auto; max-height:600px;">
                <img src="data:image/png;base64,@_renderedPngBase64" style="max-width:100%; display:block;" />
            </div>
        }
    </WindowContent>
</TelerikWindow>

@code {

    private static readonly JsonSerializerOptions _json = new() { PropertyNameCaseInsensitive = true };

    private TelerikNotification _notif = default!;

    private void NotifyError(string message) => _notif.Show(new NotificationModel
    {
        Text = message,
        ThemeColor = ThemeConstants.Notification.ThemeColor.Error,
        Closable = true,
        CloseAfter = 6000
    });

    private void NotifySuccess(string message) => _notif.Show(new NotificationModel
    {
        Text = message,
        ThemeColor = ThemeConstants.Notification.ThemeColor.Success,
        CloseAfter = 3000
    });

    private async Task<int> GetCurrentUserIdAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var value = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return int.TryParse(value, out var id) ? id : 0;
    }

    // ── State ──────────────────────────────────────────────────────

    private List<TemplateSummary> _templates = [];
    private int _selectedTemplateId;
    private TemplateDetail? _template;
    private Layer? _selectedLayer;
    private LayerSettings _activeSettings = new() { Transform = new Transform() };
    private int OpacityPercent
    {
        get => (int)(_activeSettings.Opacity * 100);
        set => _activeSettings.Opacity = value / 100m;
    }
    private int ZoomPercent
    {
        get => (int)((_activeSettings.Transform?.Zoom ?? 1) * 100);
        set => (_activeSettings.Transform ??= new Transform()).Zoom = value / 100m;
    }
    private List<Asset> _assets = [];

    private bool _isRendering;
    private bool _showAxisOverlay = true;
    private bool _loading;
    private string? _initError;
    private int? _dragSourceIndex;
    private int? _dragOverIndex;
    private string? _renderedPngBase64;
    private bool _showRenderResult;
    private bool _showNewTemplate;
    private bool _showAddMenu;
    private CreateTemplateRequest _newTemplateReq = new() { Width = 800, Height = 600 };
    private CancellationTokenSource? _saveCts;
    private IJSObjectReference? _canvasInteractModule;
    private DotNetObjectReference<Index>? _dotNetRef;

    private static readonly string[] _layerTypes = ["background", "image", "text", "shape", "overlay"];
    private static readonly List<string> _objectFitOptions = ["cover", "contain", "fill", "scale-down"];
    private static readonly List<string?> _fontFamilyOptions = ["Arial", "Verdana", "Helvetica", "Tahoma", "Trebuchet MS", "Times New Roman", "Georgia", "Garamond", "Courier New", "Lucida Console", "Comic Sans MS", "Impact", "Segoe UI"];
    private static readonly List<string?> _fontWeightOptions = [null, "normal", "bold", "300", "400", "500", "600", "700", "800", "900"];
    private static readonly List<string> _shapeTypeOptions = ["rectangle", "circle", "ellipse", "polygon", "star"];

    // ── Zoom ───────────────────────────────────────────────────────

    private record ZoomLevel(string Label, decimal? Scale);

    private static readonly ZoomLevel[] _zoomLevels =
    [
        new("Fit",  null),
        new("50%",  0.50m),
        new("75%",  0.75m),
        new("100%", 1.00m),
        new("125%", 1.25m),
        new("150%", 1.50m),
        new("175%", 1.75m),
        new("200%", 2.00m),
    ];

    private ZoomLevel _selectedZoom = _zoomLevels[3]; // 100%
    private decimal _zoom = 1.0m;
    private ElementReference _canvasWrapRef;

    private int CanvasScaledWidth  => _template == null ? 0 : (int)Math.Ceiling(_template.Width  * (double)_zoom);
    private int CanvasScaledHeight => _template == null ? 0 : (int)Math.Ceiling(_template.Height * (double)_zoom);

    private string CanvasContainerStyle => _template == null ? "" :
        $"width:{_template.Width}px; height:{_template.Height}px;" +
        $"transform:scale({_zoom.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)});" +
        "transform-origin:top left; position:absolute; top:0; left:0;";

    private async Task OnZoomChangedAsync(string label)
    {
        _selectedZoom = _zoomLevels.FirstOrDefault(z => z.Label == label) ?? _zoomLevels[3];
        if (_selectedZoom.Scale.HasValue)
        {
            _zoom = _selectedZoom.Scale.Value;
        }
        else
        {
            await ZoomToFitAsync();
        }
        if (_canvasInteractModule != null)
            await _canvasInteractModule.InvokeVoidAsync("setZoom", (double)_zoom);
    }

    private async Task ZoomToFitAsync()
    {
        if (_template == null) return;
        try
        {
            var rect = await JS.InvokeAsync<BoundingRect>("eval",
                $"(function(){{var r=document.querySelector('.designer-canvas-wrap').getBoundingClientRect();return {{width:r.width,height:r.height}};}})()");
            var availW = rect.Width  - 48;
            var availH = rect.Height - 48;
            if (availW <= 0 || availH <= 0) return;
            var scaleW = availW / _template.Width;
            var scaleH = availH / _template.Height;
            _zoom = (decimal)Math.Min(scaleW, scaleH);
        }
        catch
        {
            _zoom = 1.0m;
        }
    }

    private record BoundingRect(double Width, double Height);

    // ── Lifecycle ──────────────────────────────────────────────────

    protected override async Task OnInitializedAsync() => await RetryInitAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _canvasInteractModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/canvasInteract.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            await InitCanvasInteract();
        }
    }

    private async Task InitCanvasInteract()
    {
        if (_canvasInteractModule == null || _dotNetRef == null || _template == null) return;
        await _canvasInteractModule.InvokeVoidAsync("init", _dotNetRef, ".designer-canvas",
            (double)_zoom, _template.Width, _template.Height);
    }

    /// <summary>
    /// Called from JS when a layer is moved, resized, rotated, or zoomed via mouse.
    /// </summary>
    [JSInvokable]
    public async Task OnTransformChanged(int layerId, double x, double y, double w, double h, double rotation, double scale)
    {
        var layer = _template?.Layers.FirstOrDefault(l => l.LayerId == layerId);
        if (layer == null) return;

        // Deserialize current settings
        var settings = layer.LayerType switch
        {
            "image" => (LayerSettings)SafeDeserialize<ImageLayerSettings>(layer.SettingsJson),
            "text" => SafeDeserialize<TextLayerSettings>(layer.SettingsJson),
            "shape" => SafeDeserialize<ShapeLayerSettings>(layer.SettingsJson),
            _ => SafeDeserialize<LayerSettings>(layer.SettingsJson)
        };
        settings.Transform ??= new Transform();
        settings.Transform.PositionX = (decimal)x;
        settings.Transform.PositionY = (decimal)y;
        settings.Transform.Width = (decimal)w;
        settings.Transform.Height = (decimal)h;
        settings.Transform.Rotation = (decimal)Math.Round(rotation, 1);
        settings.Transform.Zoom = (decimal)Math.Round(scale, 4);

        // Sync to DTO
        var json = JsonSerializer.Serialize(settings, settings.GetType(), _json);
        layer.SettingsJson = json;

        // If this is the selected layer, update _activeSettings too
        if (_selectedLayer?.LayerId == layerId)
        {
            _activeSettings = settings;
            _selectedLayer = layer;
        }

        DebouncedSaveLayers();
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_canvasInteractModule != null)
        {
            try { await _canvasInteractModule.InvokeVoidAsync("dispose"); } catch { }
            await _canvasInteractModule.DisposeAsync();
        }
        _dotNetRef?.Dispose();
        _saveCts?.Cancel();
        _saveCts?.Dispose();
    }

    private async Task RetryInitAsync()
    {
        _initError = null;
        _loading = true;
        try
        {
            await LoadTemplatesAsync();
            if (_templates.Count > 0)
                await OnTemplateChangedAsync(_templates[0].TemplateId);
        }
        catch (Exception ex)
        {
            _initError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Templates ─────────────────────────────────────────────────

    private async Task LoadTemplatesAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entities = await db.Templates.ToListAsync();
        _templates = Mapper.Map<List<TemplateSummary>>(entities)
            .OrderBy(t => t.Name)
            .ToList();
    }

    private async Task OnTemplateChangedAsync(int id)
    {
        _selectedTemplateId = id;
        _selectedLayer = null;
        _activeSettings = new LayerSettings { Transform = new Transform() };
        _showAddMenu = false;
        await LoadTemplateAsync(id);
        if (_canvasInteractModule != null && _template != null)
            await _canvasInteractModule.InvokeVoidAsync("setCanvasSize", _template.Width, _template.Height);
    }

    private async Task LoadTemplateAsync(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Templates
            .FirstOrDefaultAsync(t => t.TemplateId == id);
        _template = entity == null ? null : Mapper.Map<TemplateDetail>(entity);
    }

    private void ShowNewTemplateDialog()
    {
        _newTemplateReq = new CreateTemplateRequest { Width = 800, Height = 600 };
        _showNewTemplate = true;
    }

    private async Task CreateTemplateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTemplateReq.Name)) return;
        _showNewTemplate = false;
        try
        {
            var data = new TemplateData
            {
                Name = _newTemplateReq.Name,
                Description = _newTemplateReq.Description,
                Width = _newTemplateReq.Width,
                Height = _newTemplateReq.Height,
                Tags = _newTemplateReq.Tags,
                Category = _newTemplateReq.Category
            };
            var entity = new DbTemplate
            {
                UserId = await GetCurrentUserIdAsync(),
                IsPublished = false,
                IsTemplate = true,
                TemplateJson = TemplateJsonHelper.Serialize(data),
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };
            await using var db = await DbFactory.CreateDbContextAsync();
            db.Templates.Add(entity);
            await db.SaveChangesAsync();
            await LoadTemplatesAsync();
            await OnTemplateChangedAsync(entity.TemplateId);
            NotifySuccess($"Template \"{data.Name}\" created.");
        }
        catch (Exception ex)
        {
            NotifyError($"Failed to create template: {ex.Message}");
        }
    }

    private async Task DeleteTemplateAsync()
    {
        if (_template == null) return;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.Templates.FindAsync(_template.TemplateId);
            if (entity == null) return;
            var name = TemplateJsonHelper.Deserialize(entity.TemplateJson).Name;
            db.Templates.Remove(entity);
            await db.SaveChangesAsync();
            _template = null;
            _selectedLayer = null;
            _selectedTemplateId = 0;
            await LoadTemplatesAsync();
            NotifySuccess($"Template \"{name}\" deleted.");
        }
        catch (Exception ex)
        {
            NotifyError($"Failed to delete template: {ex.Message}");
        }
    }

    // ── Asset Selection ─────────────────────────────────────────────

    private void OnAssetSelected(ImageLayerSettings imgSettings, int assetId)
    {
        imgSettings.AssetId = assetId == 0 ? null : assetId;
        if (assetId == 0) return;

        var asset = _assets.FirstOrDefault(a => a.AssetId == assetId);
        if (asset?.ImageMetaDataJson == null) return;

        var meta = JsonSerializer.Deserialize<ImageMetaData>(asset.ImageMetaDataJson, _json);
        if (meta?.Width == null || meta.Height == null) return;

        var transform = _activeSettings.Transform ??= new Transform();
        transform.Width = meta.Width.Value;
        transform.Height = meta.Height.Value;
        SyncAndSaveLayer();
    }

    // ── Layers ────────────────────────────────────────────────────

    private void SelectLayer(Layer layer)
    {
        _selectedLayer = layer;
        _showAddMenu = false;
        _activeSettings = layer.LayerType switch
        {
            "image" => SafeDeserialize<ImageLayerSettings>(layer.SettingsJson),
            "text" => SafeDeserialize<TextLayerSettings>(layer.SettingsJson),
            "shape" => SafeDeserialize<ShapeLayerSettings>(layer.SettingsJson),
            _ => SafeDeserialize<LayerSettings>(layer.SettingsJson)
        };
        _activeSettings.Transform ??= new Transform();

        if (layer.LayerType == "image" && !_assets.Any())
            _ = LoadAssetsAsync(); // fire-and-forget safe: uses its own DbContext
    }

    private async Task LoadAssetsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _assets = await db.Assets
            .OrderBy(a => a.FileName)
            .ProjectTo<Asset>(Mapper.ConfigurationProvider)
            .ToListAsync();
        StateHasChanged();
    }

    private async Task HandleAddLayerAsync(string type)
    {
        _showAddMenu = false;
        await AddLayerAsync(type);
    }

    private string NextLayerName()
    {
        int max = 0;
        if (_template != null)
        {
            foreach (var l in _template.Layers)
            {
                if (l.Name != null && l.Name.StartsWith("Layer ") && int.TryParse(l.Name[6..], out var n) && n > max)
                    max = n;
            }
        }
        return $"Layer {max + 1}";
    }

    private async Task AddLayerAsync(string type)
    {
        if (_template == null) return;
        try
        {
            var maxZ = _template.Layers.Any() ? _template.Layers.Max(l => l.ZIndex) : 0;
            var layer = new Layer
            {
                LayerId = TemplateJsonHelper.NextLayerId(_template.Layers),
                LayerType = type,
                Name = NextLayerName(),
                ZIndex = maxZ + 1
            };
            _template.Layers.Add(layer);
            await SaveLayersAsync();
            SelectLayer(layer);
        }
        catch (Exception ex)
        {
            NotifyError($"Failed to add layer: {ex.Message}");
        }
    }

    private async Task DeleteLayerAsync()
    {
        if (_selectedLayer == null || _template == null) return;
        try
        {
            _template.Layers.RemoveAll(l => l.LayerId == _selectedLayer.LayerId);
            _selectedLayer = null;
            _activeSettings = new LayerSettings { Transform = new Transform() };
            await SaveLayersAsync();
        }
        catch (Exception ex)
        {
            NotifyError($"Failed to delete layer: {ex.Message}");
        }
    }

    private async Task OnLayerDropAsync(int targetIndex)
    {
        if (_dragSourceIndex == null || _dragSourceIndex == targetIndex || _template == null) return;
        var sorted = _template.Layers.OrderByDescending(l => l.ZIndex).ToList();
        var src = _dragSourceIndex.Value;
        if (src < 0 || src >= sorted.Count || targetIndex < 0 || targetIndex >= sorted.Count) return;

        var moved = sorted[src];
        sorted.RemoveAt(src);
        sorted.Insert(targetIndex, moved);

        // Reassign ZIndex values in descending order (first in list = highest ZIndex)
        for (int i = 0; i < sorted.Count; i++)
            sorted[i].ZIndex = sorted.Count - i;

        _template.Layers = sorted;
        _dragSourceIndex = null;
        _dragOverIndex = null;

        try
        {
            await SaveLayersAsync();
        }
        catch (Exception ex)
        {
            NotifyError($"Failed to reorder layers: {ex.Message}");
        }
    }

    private void ToggleLayerVisibility(Layer layer)
    {
        var node = JsonNode.Parse(layer.SettingsJson ?? "{}") ?? new JsonObject();
        var current = node["isVisible"]?.GetValue<bool>() ?? true;
        node["isVisible"] = !current;
        layer.SettingsJson = node.ToJsonString(_json);

        // If this is the selected layer, sync _activeSettings too
        if (_selectedLayer?.LayerId == layer.LayerId)
            _activeSettings.IsVisible = !current;

        DebouncedSaveLayers();
    }

    /// <summary>
    /// Syncs _activeSettings to the layer DTO immediately (so canvas updates)
    /// and debounces a DB save 500ms after the last change.
    /// </summary>
    private void SyncAndSaveLayer()
    {
        if (_selectedLayer == null) return;

        // Sync to DTO immediately so canvas re-renders
        var json = JsonSerializer.Serialize(_activeSettings, _activeSettings.GetType(), _json);
        _selectedLayer.SettingsJson = json;
        var dto = _template?.Layers.FirstOrDefault(l => l.LayerId == _selectedLayer.LayerId);
        if (dto != null && dto != _selectedLayer) dto.SettingsJson = json;

        DebouncedSaveLayers();
    }

    private void DebouncedSaveLayers()
    {
        _saveCts?.Cancel();
        _saveCts = new CancellationTokenSource();
        _ = DebouncedSaveLayersAsync(_saveCts.Token);
    }

    private async Task DebouncedSaveLayersAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(500, token);
            await SaveLayersAsync();
        }
        catch (TaskCanceledException) { /* debounced — newer save pending */ }
        catch (Exception ex)
        {
            await InvokeAsync(() => { NotifyError($"Auto-save failed: {ex.Message}"); StateHasChanged(); });
        }
    }

    private async Task SaveLayersAsync()
    {
        if (_template == null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Templates.FindAsync(_template.TemplateId);
        if (entity == null) return;
        var data = TemplateJsonHelper.Deserialize(entity.TemplateJson);
        data.Layers = _template.Layers;
        entity.TemplateJson = TemplateJsonHelper.Serialize(data);
        entity.UpdatedAt = DateTime.UtcNow;
        await db.SaveChangesAsync();
    }

    // ── Render ────────────────────────────────────────────────────

    private async Task RenderPngAsync()
    {
        if (_template == null) return;
        _isRendering = true;
        try
        {
            var bytes = await DesignService.RenderAsync(_template.TemplateId);
            _renderedPngBase64 = Convert.ToBase64String(bytes);
            _showRenderResult = true;
        }
        catch (Exception ex)
        {
            NotifyError($"Render failed: {ex.Message}");
        }
        finally
        {
            _isRendering = false;
        }
    }

    // ── Canvas helpers ────────────────────────────────────────────

    private string GetLayerStyle(Layer layer)
    {
        try
        {
            var s = SafeDeserialize<LayerSettings>(layer.SettingsJson);
            if (!s.IsVisible) return "display:none;";

            var sb = new StringBuilder("position:absolute; cursor:pointer; box-sizing:border-box;");
            var t = s.Transform;
            var isFullBleed = layer.LayerType is "background" or "overlay";

            if (isFullBleed || t == null || (!t.PositionX.HasValue && !t.PositionY.HasValue && !t.Width.HasValue && !t.Height.HasValue))
            {
                if (isFullBleed) sb.Append("inset:0;");
                else sb.Append(CultureInfo.InvariantCulture, $"top:0; left:0; width:{_template!.Width}px; height:{_template!.Height}px;");
            }
            else
            {
                sb.Append(CultureInfo.InvariantCulture, $"left:{t.PositionX ?? 0}px; top:{t.PositionY ?? 0}px;");
                if (t.Width.HasValue) sb.Append(CultureInfo.InvariantCulture, $"width:{t.Width}px;");
                if (t.Height.HasValue) sb.Append(CultureInfo.InvariantCulture, $"height:{t.Height}px;");
                var hasRotation = t.Rotation is { } r and not 0;
                var hasZoom = t.Zoom.HasValue && t.Zoom != 1;
                if (hasRotation || hasZoom)
                {
                    sb.Append("transform:");
                    if (hasZoom) sb.Append(CultureInfo.InvariantCulture, $"scale({t.Zoom})");
                    if (hasRotation) sb.Append(CultureInfo.InvariantCulture, $" rotate({t.Rotation}deg)");
                    sb.Append(';');
                }
            }

            sb.Append(CultureInfo.InvariantCulture, $"opacity:{s.Opacity};");

            switch (layer.LayerType)
            {
                case "background":
                    sb.Append($"background-color:{s.BackgroundColor ?? "#f0f0f0"};");
                    break;
                case "overlay":
                    sb.Append($"background-color:{s.BackgroundColor ?? "rgba(0,0,0,0.5)"};");
                    break;
                case "image":
                    var imgS = SafeDeserialize<ImageLayerSettings>(layer.SettingsJson);
                    var filters = new List<string>();
                    if (imgS.FilterBrightness.HasValue && imgS.FilterBrightness != 100)
                        filters.Add(FormattableString.Invariant($"brightness({imgS.FilterBrightness / 100m})"));
                    if (imgS.FilterContrast.HasValue && imgS.FilterContrast != 100)
                        filters.Add(FormattableString.Invariant($"contrast({imgS.FilterContrast / 100m})"));
                    if (imgS.FilterSaturation.HasValue && imgS.FilterSaturation != 100)
                        filters.Add(FormattableString.Invariant($"saturate({imgS.FilterSaturation / 100m})"));
                    if (imgS.FilterHue is > 0)
                        filters.Add(FormattableString.Invariant($"hue-rotate({imgS.FilterHue}deg)"));
                    if (imgS.FilterGrayscale is > 0)
                        filters.Add(FormattableString.Invariant($"grayscale({imgS.FilterGrayscale / 100m})"));
                    if (imgS.FilterBlur is > 0)
                        filters.Add(FormattableString.Invariant($"blur({imgS.FilterBlur}px)"));
                    if (filters.Count > 0)
                        sb.Append($"filter:{string.Join(" ", filters)};");
                    break;
                case "shape":
                    var ss = SafeDeserialize<ShapeLayerSettings>(layer.SettingsJson);
                    if (ss.FillColor != null) sb.Append($"background-color:{ss.FillColor};");
                    if (ss.StrokeColor != null && ss.StrokeWidth > 0)
                        sb.Append(CultureInfo.InvariantCulture, $"border:{ss.StrokeWidth}px solid {ss.StrokeColor};");
                    if (ss.ShapeType is "circle" or "ellipse")
                        sb.Append("border-radius:50%;");
                    else if (ss.BorderRadiusTL > 0)
                        sb.Append(CultureInfo.InvariantCulture, $"border-radius:{ss.BorderRadiusTL}px;");
                    break;
                case "text":
                    var ts = SafeDeserialize<TextLayerSettings>(layer.SettingsJson);
                    sb.Append($"color:{s.BackgroundColor ?? "#ffffff"}; white-space:pre-wrap; padding:4px;");
                    sb.Append($"font-family:'{ts.FontFamily ?? "Arial"}';");
                    sb.Append(CultureInfo.InvariantCulture, $"font-size:{ts.FontSize ?? 24}px;");
                    if (ts.FontWeight != null) sb.Append($"font-weight:{ts.FontWeight};");
                    break;
            }

            return sb.ToString();
        }
        catch
        {
            return "position:absolute; inset:0;";
        }
    }

    // ── Utilities ─────────────────────────────────────────────────

    private static T SafeDeserialize<T>(string? json) where T : LayerSettings, new()
    {
        if (string.IsNullOrEmpty(json)) return new T();
        try { return JsonSerializer.Deserialize<T>(json, _json) ?? new T(); }
        catch { return new T(); }
    }
}
